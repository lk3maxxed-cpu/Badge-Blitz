{% comment %} Badge Blitz — App Embed Block {% endcomment %}
{% comment %}
  This block is enabled store-wide in Customize > App embeds.
  It injects badge overlays onto product cards across the storefront.
{% endcomment %}

{{ 'badge-blitz.css' | asset_url | stylesheet_tag }}

<script>
  window.BadgeBlitzShop = {{ shop.permanent_domain | json }};
  window.BadgeBlitzApiUrl = "";
</script>

<script src="{{ 'badge-blitz.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Badge Blitz",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL (direct fallback, proxy used by default)",
      "default": "https://badge-blitz-production.up.railway.app"
    }
  ]
}
{% endschema %}
